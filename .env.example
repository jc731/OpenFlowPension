# PostgreSQL — use service name 'postgres' when running inside Docker
DATABASE_URL=postgresql+asyncpg://openflow:changeme@postgres:5432/openflow_pension
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# Fernet key for SSN encryption at rest
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

ENVIRONMENT=development

# Keycloak JWT — leave blank in development (dev bypass applies)
# Set ENVIRONMENT=production to disable the dev bypass and require real tokens.
# KEYCLOAK_URL=http://keycloak:8080
# KEYCLOAK_REALM=openflow
# KEYCLOAK_AUDIENCE=openflow-admin
