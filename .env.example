# PostgreSQL — use service name 'postgres' when running inside Docker
DATABASE_URL=postgresql+asyncpg://openflow:changeme@postgres:5432/openflow_pension
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# Fernet key for SSN encryption at rest
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

ENVIRONMENT=development
# Set to 'production' to disable the dev-admin bypass and require real auth tokens.
# In production every request must carry a valid Bearer token (Keycloak JWT or ofp_ API key).

# Keycloak JWT — leave all three blank in development; the dev bypass applies when ENVIRONMENT=development.
# Run `make auth-up` to start Keycloak alongside the main stack.
# After first start, create staff users in the Keycloak admin UI at http://localhost:8080.
# KEYCLOAK_URL=http://keycloak:8080
# KEYCLOAK_REALM=openflow
# KEYCLOAK_AUDIENCE=openflow-admin
